@page "/tickets/create"
@attribute [Authorize]
@inject TicketApiService TicketApi
@inject NavigationManager Nav

<PageTitle>New Ticket — AI Support Triage</PageTitle>

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="mb-3">
            <a href="/tickets" class="text-decoration-none text-muted small">
                <i class="bi bi-arrow-left me-1"></i>Back to Tickets
            </a>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius:16px;">
            <div class="card-body p-4">

                <h5 class="fw-bold mb-1">Submit Support Ticket</h5>
                <p class="text-muted small mb-4">
                    Our AI automatically classifies, prioritises, and routes your ticket.
                </p>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger py-2 small">
                        <i class="bi bi-exclamation-circle me-1"></i>@_error
                    </div>
                }

                @if (_success)
                {
                    <div class="alert alert-success py-2 small">
                        <i class="bi bi-check-circle me-1"></i>
                        Ticket submitted! Redirecting...
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Subject / Title <span class="text-danger">*</span>
                    </label>
                    <input class="form-control"
                           @bind="_model.Title"
                           @bind:event="oninput"
                           placeholder="Brief description of your issue"
                           maxlength="200" />
                    <div class="form-text">@_model.Title.Length / 200</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Description <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control"
                              rows="7"
                              @bind="_model.Description"
                              @bind:event="oninput"
                              placeholder="Describe your issue in detail — include error messages, steps to reproduce, and what you expected."
                              maxlength="5000"></textarea>
                    <div class="form-text">@_model.Description.Length / 5000</div>
                </div>

                <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light mb-4">
                    <i class="bi bi-robot fs-4 text-primary"></i>
                    <div>
                        <div class="fw-semibold small">AI-Powered Triage</div>
                        <div class="text-muted" style="font-size:12px;">
                            AI will analyse sentiment, classify the category, detect urgency,
                            and auto-assign the best available agent — all asynchronously.
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1"
                            @onclick="SubmitAsync"
                            disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"
                                  role="status"></span>
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <i class="bi bi-send me-1"></i>
                            <span>Submit Ticket</span>
                        }
                    </button>
                    <a href="/tickets" class="btn btn-outline-secondary">Cancel</a>
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private readonly CreateTicketRequest _model = new();
    private string _error = string.Empty;
    private bool _submitting = false;
    private bool _success = false;

    private async Task SubmitAsync()
    {
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(_model.Title) || _model.Title.Trim().Length < 5)
        {
            _error = "Title must be at least 5 characters.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_model.Description) || _model.Description.Trim().Length < 10)
        {
            _error = "Description must be at least 10 characters.";
            return;
        }

        _submitting = true;

        // Return type is now TicketDetailDto
        var (ticket, error) = await TicketApi.CreateTicketAsync(_model);

        _submitting = false;

        if (ticket != null)
        {
            _success = true;
            StateHasChanged();
            await Task.Delay(800);
            Nav.NavigateTo($"/tickets/{ticket.Id}");
        }
        else
        {
            _error = error ?? "Failed to submit ticket. Please try again.";
        }
    }
}