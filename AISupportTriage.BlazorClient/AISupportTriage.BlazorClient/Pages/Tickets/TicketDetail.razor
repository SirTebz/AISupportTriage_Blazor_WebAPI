@page "/tickets/{Id:guid}"
@attribute [Authorize]
@inject TicketApiService TicketApi
@inject SignalRService SignalR
@inject NavigationManager Nav

<PageTitle>Ticket Detail — AI Support Triage</PageTitle>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (_ticket == null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-exclamation-circle fs-1 d-block mb-3"></i>
        <h5>Ticket not found</h5>
        <a href="/tickets" class="btn btn-outline-primary mt-2">Back to Tickets</a>
    </div>
}
else
{
    <div class="mb-3">
        <a href="/tickets" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left me-1"></i>Back to Tickets
        </a>
    </div>

    <div class="row g-3">

        <!-- ── Left Column ─────────────────────────────── -->
        <div class="col-lg-8">

            <!-- Header -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
                        <h5 class="fw-bold mb-0">@_ticket.Title</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <StatusBadge Status="@_ticket.Status" />
                            <PriorityBadge Priority="@_ticket.Priority" />
                        </div>
                    </div>
                    <p class="text-secondary mb-3" style="white-space:pre-wrap;">
                        @_ticket.Description
                    </p>
                    <div class="text-muted small">
                        Submitted by <strong>@_ticket.CreatedByName</strong> on
                        @_ticket.CreatedAt.ToString("MMM dd, yyyy HH:mm") UTC
                    </div>
                </div>
            </div>

            <!-- Conversation -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-chat-left-dots me-2 text-primary"></i>Conversation
                    </h6>

                    @if (!_ticket.Messages.Any())
                    {
                        <p class="text-muted small text-center py-3">
                            No messages yet. Be the first to reply.
                        </p>
                    }

                    @foreach (var msg in _ticket.Messages)
                    {
                        var isAiMsg = msg.SenderId == "System"
                        || msg.Content.StartsWith("[AI");
                        var cssClass = isAiMsg ? "message-ai"
                        : msg.IsInternal ? "message-internal"
                        : msg.SenderId == _ticket.CreatedById
                        ? "message-user"
                        : "message-agent";
                        <div class="message-bubble @cssClass mb-3">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                @if (isAiMsg)
                                {
                                    <span class="badge-ai">
                                        <i class="bi bi-robot me-1"></i>AI Suggestion
                                    </span>
                                }
                                else
                                {
                                    <strong class="small">@msg.SenderName</strong>
                                    @if (msg.IsInternal)
                                    {
                                        <span class="badge bg-warning text-dark"
                                              style="font-size:10px;">Internal</span>
                                    }
                                }
                            <span class="text-muted ms-auto" style="font-size:11px;">
                                @msg.CreatedAt.ToString("MMM dd, HH:mm")
                            </span>
                        </div>
                        <div style="white-space:pre-wrap;font-size:14px;">
                            @(isAiMsg
                                                    ? msg.Content.Replace("[AI Suggestion] ", "")
                                                    : msg.Content)
                            </div>
                        </div>
                    }

                    <!-- Reply box -->
                    @if (!string.IsNullOrEmpty(_replyError))
                    {
                        <div class="alert alert-danger py-2 small">@_replyError</div>
                    }

                    <div class="border-top pt-3 mt-2">
                        <textarea class="form-control mb-2"
                                  rows="3"
                                  @bind="_replyContent"
                                  @bind:event="oninput"
                                  placeholder="Type your reply..."></textarea>
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox"
                                       id="internalNote"
                                       @bind="_isInternalNote" />
                                <label class="form-check-label small" for="internalNote">
                                    Internal note (agents only)
                                </label>
                            </div>
                            <button class="btn btn-primary btn-sm"
                                    @onclick="SendReplyAsync"
                                    disabled="@_sending">
                                @if (_sending)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"
                                          role="status"></span>
                                }
                                <i class="bi bi-send me-1"></i>Send
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Right Column ────────────────────────────── -->
        <div class="col-lg-4">

            <!-- AI Analysis -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h6 class="fw-bold mb-0">
                            <i class="bi bi-robot me-2 text-primary"></i>AI Analysis
                        </h6>
                        @if (_ticket.AiAnalysisComplete)
                        {
                            <span class="badge-ai">Complete</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                <span class="spinner-border spinner-border-sm me-1"
                                      style="width:10px;height:10px;"></span>
                                Processing
                            </span>
                        }
                    </div>

                    @if (_ticket.AiAnalysisComplete)
                    {
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Sentiment</span>
                                <span class="@SentimentClass fw-semibold">@SentimentLabel</span>
                            </div>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar @SentimentBarClass"
                                     style="width:@SentimentPct%"></div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Urgency</span>
                                <span class="@UrgencyClass fw-semibold">@UrgencyLabel</span>
                            </div>
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar @UrgencyBarClass"
                                     style="width:@UrgencyPct%"></div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(_ticket.SuggestedTags))
                        {
                            <div>
                                <p class="text-muted small mb-1">Suggested Tags</p>
                                @foreach (var tag in _ticket.SuggestedTags
                                                    .Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge bg-light text-dark border me-1 mb-1">
                                        @tag.Trim()
                                    </span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted small mb-0">
                            Analysis is running in the background.
                            The page will update automatically.
                        </p>
                    }
                </div>
            </div>

            <!-- Details -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">Details</h6>

                    <MetaRow Label="Category"
                             Value="@_ticket.Category" />
                    <MetaRow Label="Assigned To"
                             Value="@(_ticket.AssignedAgentName ?? "Unassigned")" />

                    @if (_ticket.SLADeadline.HasValue)
                    {
                        <div class="d-flex justify-content-between align-items-center
                                            py-2 border-bottom">
                            <span class="text-muted small">SLA Deadline</span>
                            <span class="small @(_ticket.SlaBreached ? "text-danger fw-bold" : "")">
                                @_ticket.SLADeadline.Value.ToString("MMM dd HH:mm")
                                @if (_ticket.SlaBreached)
                                {
                                    <span class="badge bg-danger ms-1">Breached</span>
                                }
                            </span>
                        </div>
                    }

                    @if (_ticket.ResolvedAt.HasValue)
                    {
                        <MetaRow Label="Resolved At"
                                 Value="@_ticket.ResolvedAt.Value.ToString("MMM dd HH:mm")" />
                    }

                    <AuthorizeView Roles="CompanyAdmin,SupportAgent">
                        <Authorized>
                            <div class="mt-3 pt-2 border-top">
                                <label class="form-label small fw-semibold">
                                    Update Status
                                </label>
                                <select class="form-select form-select-sm mb-2"
                                        @bind="_newStatus">
                                    <option value="0">Open</option>
                                    <option value="2">In Progress</option>
                                    <option value="3">Waiting on Customer</option>
                                    <option value="4">Resolved</option>
                                    <option value="5">Closed</option>
                                </select>
                                <button class="btn btn-outline-primary btn-sm w-100"
                                        @onclick="UpdateStatusAsync">
                                    <i class="bi bi-check2-circle me-1"></i>Apply
                                </button>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>

            <!-- Audit Log -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="bi bi-clock-history me-2 text-muted"></i>Activity Log
                    </h6>
                    @if (!_ticket.AuditLogs.Any())
                    {
                        <p class="text-muted small">No activity yet.</p>
                    }
                    @foreach (var log in _ticket.AuditLogs.Take(10))
                    {
                        <div class="d-flex gap-2 mb-2">
                            <div class="text-muted"
                                 style="font-size:10px;white-space:nowrap;padding-top:2px;">
                                @log.Timestamp.ToString("MMM dd HH:mm")
                            </div>
                            <div style="font-size:12px;">
                                <span class="badge bg-light text-dark border me-1">
                                    @log.Action
                                </span>
                                @if (!string.IsNullOrEmpty(log.NewValue))
                                {
                                    <span class="text-muted">→ @log.NewValue</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    // *** KEY FIX: type is now TicketDetailDto, not TicketDetail ***
    private TicketDetailDto? _ticket = null;
    private bool _loading = true;
    private string _replyContent = string.Empty;
    private bool _isInternalNote = false;
    private bool _sending = false;
    private string _replyError = string.Empty;
    private int _newStatus = 2;

    // ── AI score helpers ──────────────────────────────────────────────────────
    private double Sentiment => _ticket?.SentimentScore ?? 0.5;
    private double Urgency => _ticket?.UrgencyScore ?? 0.5;

    private string SentimentLabel => Sentiment < 0.3 ? "Negative"
                                      : Sentiment < 0.6 ? "Neutral" : "Positive";
    private string SentimentClass => Sentiment < 0.3 ? "text-danger"
                                      : Sentiment < 0.6 ? "text-muted" : "text-success";
    private string SentimentBarClass => Sentiment < 0.3 ? "bg-danger"
                                      : Sentiment < 0.6 ? "bg-warning" : "bg-success";
    private string SentimentPct => ((int)(Sentiment * 100)).ToString();

    private string UrgencyLabel => Urgency > 0.85 ? "Critical"
                                      : Urgency > 0.65 ? "High"
                                      : Urgency > 0.40 ? "Medium" : "Low";
    private string UrgencyClass => Urgency > 0.65 ? "text-danger"
                                      : Urgency > 0.40 ? "text-warning" : "text-muted";
    private string UrgencyBarClass => Urgency > 0.65 ? "bg-danger"
                                      : Urgency > 0.40 ? "bg-warning" : "bg-success";
    private string UrgencyPct => ((int)(Urgency * 100)).ToString();

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        SignalR.OnTicketUpdated += OnTicketUpdated;
        SignalR.OnNewMessage += OnNewMessage;
        await LoadTicketAsync();
    }

    private async void OnTicketUpdated(string id)
    {
        if (id == Id.ToString())
        {
            await LoadTicketAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnNewMessage(string id)
    {
        if (id == Id.ToString())
        {
            await LoadTicketAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadTicketAsync()
    {
        _loading = true;
        StateHasChanged();
        _ticket = await TicketApi.GetTicketAsync(Id);
        _loading = false;
    }

    private async Task SendReplyAsync()
    {
        _replyError = string.Empty;
        if (string.IsNullOrWhiteSpace(_replyContent)) return;

        _sending = true;
        var (msg, error) = await TicketApi.AddMessageAsync(
            Id, _replyContent, _isInternalNote);
        _sending = false;

        if (msg != null)
        {
            _ticket?.Messages.Add(msg);
            _replyContent = string.Empty;
            _isInternalNote = false;
        }
        else
        {
            _replyError = error ?? "Failed to send message.";
        }
    }

    private async Task UpdateStatusAsync()
    {
        var (updated, _) = await TicketApi.UpdateStatusAsync(Id, _newStatus);
        if (updated != null) _ticket = updated;
    }
}