@page "/register"
@layout EmptyLayout
@inject AuthClientService AuthSvc
@inject NavigationManager Nav

<div class="auth-bg">
    <div class="card auth-card" style="width:480px;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <div style="font-size:3rem;">🚀</div>
                <h3 class="fw-bold mt-2">Start Free Trial</h3>
                <p class="text-muted">Set up your company's support platform</p>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-1"></i>@_error
                </div>
            }

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">First Name</label>
                    <input class="form-control"
                           @bind="_model.AdminFirstName"
                           placeholder="John" />
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">Last Name</label>
                    <input class="form-control"
                           @bind="_model.AdminLastName"
                           placeholder="Smith" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Company Name</label>
                <input class="form-control"
                       @bind="_model.CompanyName"
                       placeholder="Acme Corp" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Work Email</label>
                <input type="email"
                       class="form-control"
                       @bind="_model.AdminEmail"
                       placeholder="you@company.com" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Password</label>
                <input type="password"
                       class="form-control"
                       @bind="_model.AdminPassword"
                       placeholder="Min 6 chars, 1 uppercase digit" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Plan</label>
                <select class="form-select" @bind="_model.Plan">
                    <option value="Free">Free — 24h SLA</option>
                    <option value="Pro">Pro — 8h SLA</option>
                    <option value="Enterprise">Enterprise — 4h SLA</option>
                </select>
            </div>

            <button class="btn btn-primary btn-lg w-100 mb-3"
                    @onclick="HandleRegisterAsync"
                    disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"
                          role="status"></span>
                }
                Create Account
            </button>

            <div class="text-center">
                <a href="/login" class="text-decoration-none small">
                    Already have an account? Sign in
                </a>
            </div>

        </div>
    </div>
</div>

@code {
    private readonly RegisterRequest _model = new();
    private string _error = string.Empty;
    private bool _loading = false;

    private async Task HandleRegisterAsync()
    {
        _error = string.Empty;
        _loading = true;

        var (success, error) = await AuthSvc.RegisterAsync(_model);

        _loading = false;

        if (success)
            Nav.NavigateTo("/", replace: true);
        else
            _error = error ?? "Registration failed.";
    }
}